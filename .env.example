# RedThread environment configuration
# Copy to .env and customize

# FalkorDB connection
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH_NAME=redthread

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_LOG_LEVEL=info

# SQLite (for case management metadata)
SQLITE_DB_PATH=./data/redthread.db

# Security
SECRET_KEY=change-me-in-production

# LLM for Natural Language → Cypher (optional)
# Supports OpenAI, Azure OpenAI, or any OpenAI-compatible API
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
